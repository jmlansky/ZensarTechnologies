{
  "Logging": {
    "LogLevel": {
      "Default": "Information"
    }
  },
  "ConnectionStrings": {
    "WebDownloader": "Data Source=webdownloader.db"
  },
  "PageDownload": {
    "DownloadsRoot": "Downloads",
    "MaxConcurrency": 3,
    "MaxAttempts": 3,
    "MaxLinkedPages": 10,
    "UserAgent": "Mozilla/5.0 (compatible; WebDownloader/1.0)",
    "AcceptHeader": "text/html,application/xhtml+xml,application/xml;q=0.9,*/*;q=0.8"
  }
}
